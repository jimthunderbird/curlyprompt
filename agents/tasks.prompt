target_file: ./local_action_agent.sh

objectivie: perform all tasks to modify {target_file}

constraint {
  after a task {task} is completed, update ./tasks.prompt {
    mark {task} as completed
  }
  do not run completed tasks
}

task (completed) {
  after cd $1, if git status shows no file changed {
    run cli: node $ACTION_FILE
    exit 1
  }
}

task (completed) {
  we have: 
    for f in *.prompt; do
      PROMPT+=$'\n'
      PROMPT+=$(cat "$f")
      PROMPT+=$'\n'
    done
  we should change it to use: find . -type f -name "*.prompt"
}

task (completed) {
  when running {target_file}, we have the following errors:
  line 39: syntax error near unexpected token `<'
}

task (completed) {
  before:
    node $ACTION_FILE
  print a message "running action..." 
}

task.no_prompt_files_changed (completed) {
  after cd $1, if git status shows no .prompt file changed {
    run cli: node $ACTION_FILE
    exit 1
  }
}

task (completed) {
  in task.no_prompt_files_changed, change to the following logic {
    after cd $1, if git status shows no non tasks.prompt .prompt file changed {
      run cli: node $ACTION_FILE
      exit 1
    }
  }
}
