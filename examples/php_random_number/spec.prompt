role: PHP 8 Expert

objective: {
  generate spec.php based on app_spec below, no extra words, no explanation
  must pass tests
}

app_spec {
  logic {
    let numbers = get 100 random numbers ranging from 1 to 500
    foreach({numbers} as {number}) {
      print {number} with newline
    }
  }
}

tests {
  - must use shuffle and array_slice
  - must not have any functions
}
