role: PHP8/HTML/CSS/Javascript Expert

objective: create a single page web application based on spec and run all asks

constraint {
  all related php logic must be at the very top of the page, all html/css/javascript should be after, example {
    <?php
    ...
    ?>
    <html>
    ...
    </html>
  }
}

spec {
  php { #the php code
    read_book_url(url) { #a php function to read the book content from a given book url
      let result = use php to get the file content of {url}
      result = split {result} by newline and convert them to html paragraphs
      return result
    }
  }

  html { # the html code
    style {
      background: wheat
    }

    javascript {
      load_book(url) {
        send POST payload {
          action:"read_book_url"
          url:{url}
        } to php.read_book_url(url)
      }  
    }

    layout { #the html layout
      div.id:"book-controls" {
        textbox.id:"book-url" {
          @key.enter  {
            div.id:"book-content".html = load_book(textbox.id:"book-url".value)
          }
        }
      }

      div.id:"book-content" {
        html:""  
      }
    }
  }
}
