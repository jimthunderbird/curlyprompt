role: PHP8/HTML/CSS/Javascript Expert

objective: create a single page web application based on spec and run all asks

constraint {
  everything should be in {spec.entrypoint}, including all the php code, html, css and javascript
  no other files should be created
  all related php logic must be at the very top of the page, all html/css/javascript should be after, example {
    <?php
    ...
    ?>
    <html>
    ...
    </html>
  }
}

spec {
  php { #the php code
    read_book_url(url) { #a php function to read the book content from a given book url
      let result = use php to get the file content of {url}
      result = split {result} by newline and convert them to html paragraphs
      return result
    }

    if (php get variable action is "load_book") {
      let url = php get variable url
      let content = file_get_contents(url)
      if (content !== false) {
        let lines = explode("\n", content)
        let html = ""
        foreach (lines as line) {
          if (trim(line) !== "") {
            html = html . "<p>" . htmlspecialchars(line) . "</p>"
          }
        }
        echo html
      } else {
        echo "<p>Error loading book content</p>"
      }
      exit
    }
  }

  html { # the html code
    style {
      background: wheat
    }

    layout { #the html layout
      div.id:"book-controls" {
        textbox.id:"book-url" {
          @key.enter  {
            let xhr = new XMLHttpRequest()
            xhr.open("GET", "?action=load_book&url=" + encodeURIComponent(self.value), true)
            xhr.onreadystatechange = function() {
              if (xhr.readyState === 4 && xhr.status === 200) {
                document.getElementById("book-content").innerHTML = xhr.responseText
              }
            }
            xhr.send()
          }
        }
      }

      div.id:"book-content" {
        html:""  
      }
    }
  }
}

task {
  after book url is entered, the book content does not show, please fix it
}
