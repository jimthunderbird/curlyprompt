perform a loop {
  run cli command: sh ./local_llm_codegen.sh
  N = (number of .prompt files in ./tests directory)
  let num_of_passed_test = 0
  for (i=1; i<={N}; i++) {
    run cli command: node action.js ./tests/test_markdown_{i}.prompt ./tests/test{i}_tmpoutput.md
    if (the content of ./tests/test{i}_tmpoutput.md is identical to ./tests/test_markdown_{i}.md) {
      num_of_passed_test ++  
    } 
  }

  if ({num_of_passed_test} equals to {N}) {
    break
  } else {
    update ./Converter.prompt only, add more details there to fix the possible issues
  }
}
