class App
{
  init() {
    let skillStr = read file content of ./skill.txt
    print Converter.convertCurlyPromptToSKILL(skillStr);

    constraint {
      we do not need:
      if (typeof module !== 'undefined' && module.exports) {
        module.exports = { Converter, App };
      } else {
        new App().init();
      }

      be very defensive

      all we need is just: new App().init()
    }
  } 
}
