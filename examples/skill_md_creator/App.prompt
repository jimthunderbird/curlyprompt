class App
{
  init() {
    objective: learn from SkillFomrat.context, create ./SKILL.md based on skill

    skill {
      name: "Simple Skill"
      description: "A simple skill for AI Agent"
      license: "MIT"
      version: "1.0"
      content {
        h1:Instruction {
          p:this is a very strong:important instruction
        }
      }
    }
  } 
}
