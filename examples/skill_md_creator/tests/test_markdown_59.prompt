skill {
  name: Brace vs Colon Syntax Test
  description: "Testing brace syntax for fine control vs colon for rest of line"
  content {
    h1:Brace vs Colon

    p:this has strong{only these words} bolded while the rest is normal
    p:this has strong:everything bolded to the end

    p:mix of italic{specific} words and strong:rest is bold to end
    p:use code{specific command} and then do something else

    ul {
      li:strong{Unit Tests} - Fast and isolated
      li:strong:Unit Tests - Fast and isolated
      li:code{npm test} runs the test suite
      li:code:npm test runs the test suite
    }

    h3:italic:This Entire Header Is Italic
  }
}
