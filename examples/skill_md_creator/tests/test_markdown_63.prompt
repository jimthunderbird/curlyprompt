skill    {
  name: Flexible Spacing Test
  description: Test flexible spacing between tag names and opening braces
  header    {
    license: MIT
  }
  content    {
    h1:Flexible Spacing

    p    {
      This paragraph has spaces before the brace.
    }

    ul    {
      li:item one
      li:item two
    }

    ol    {
      li:first
      li:second
    }

    code    {
      console.log("hello");
    }

    bq:this is a quote

    table    {
      tr    {
        th:Name
        th:Value
      }
      tr    {
        td:A
        td:1
      }
    }

    p:testing strong   {bold text} in a sentence
    p:testing italic   {italic text} in a sentence
    p:testing code   {inline code} in a sentence
  }
}
