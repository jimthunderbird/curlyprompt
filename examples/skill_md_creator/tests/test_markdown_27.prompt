skill {
  name: "All Elements Stress Test"
  description: "A comprehensive test using every supported element type"
  license: "GPL-3.0"
  version: "1.0"
  content {
    h1:Complete Element Reference {
      p:This document demonstrates strong:every supported element.

      h2:Text Formatting
      p:Here is strong:bold text and italic:italic text in paragraphs.
      p:You can also use code:inline code within text.

      h2:Blockquotes
      blockquote:This is a simple blockquote.
      blockquote:This blockquote contains strong:bold and italic:italic text.

      h2:Unordered List
      ul {
        li:First unordered item
        li:Second with strong:bold word
        li:Third with italic:emphasis
        li:Fourth with code:inline code
        li:Fifth with link:a link:https://example.com
      }

      h2:Ordered List
      ol {
        li:First ordered item
        li:Second ordered item
        li:Third ordered item
      }

      hr

      h2:Code Block
      code {
        function hello() {
          console.log("Hello, world!");
          return true;
        }
      }

      h2:Links and Images
      p:Visit link:Example Site:https://example.com for more info.
      img:Example Image:assets/example.png

      hr

      h3:Final Notes
      p:This concludes the element reference.
      blockquote:Remember to test all elements thoroughly.
    }
  }
}
