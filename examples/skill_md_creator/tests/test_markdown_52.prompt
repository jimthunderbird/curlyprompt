skill {
  name: Table Test Advanced
  content {
    h2:Employee Directory

    table {
      tr {
        th: Employee
        th: Department
        th: Status
      }
      tr {
        td: strong{John Smith}
        td: Engineering
        td: Active
      }
      tr {
        td: italic{Jane Doe}
        td: Marketing
        td: On Leave
      }
      tr {
        td: Bob Wilson
        td: Sales
        td: Active
      }
    }

    p:This table shows all employees.
  }
}
