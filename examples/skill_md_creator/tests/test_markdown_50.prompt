skill {
  name: "Header Levels h4-h6 Test"
  description: "Test h4 h5 h6 headers with formatting"
  content {
    h1:Main Title
    p:intro paragraph

    h2:Section Two
    p:some content

    h3:Section Three
    p:more content

    h4:Section Four
    p:details here

    h5:Section Five
    p:finer details

    h6:Section Six
    p:finest details

    h4:Bold strong:Header in h4
    h5:Italic italic{styled} h5
    h6:Code code:snippet in h6

    h4:Grouped Section {
      p:content inside h4 section
    }
  }
}
