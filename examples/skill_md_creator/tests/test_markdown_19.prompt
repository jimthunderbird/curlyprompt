skill {
  name: "Security Checklist"
  description: "Application security review checklist"
  license: "MIT"
  version: "2.0"
  content {
    h1:Security Review Checklist
    blockquote:Security is everyone's responsibility.

    h2:Authentication
    ul {
      li:Use strong:bcrypt for password hashing
      li:Implement rate limiting on login endpoints
      li:Enable strong:two-factor authentication
    }

    h2:Data Protection
    ol {
      li:Encrypt data at rest
      li:Use TLS for data in transit
      li:Sanitize all user inputs
      li:Use parameterized queries
    }

    h2:Resources
    p:Refer to the link:OWASP Top 10:https://owasp.org/www-project-top-ten/ for common vulnerabilities.
    p:See also link:Security Best Practices:https://example.com/security-guide for internal guidelines.

    hr

    h2:Incident Response
    p:In case of a security incident:
    ol {
      li:strong:Contain the breach immediately
      li:Notify the security team
      li:Document the incident
      li:Perform a post-mortem
    }
  }
}
