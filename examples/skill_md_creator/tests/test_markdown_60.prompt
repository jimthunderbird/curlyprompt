skill {
  name: Shortcut Aliases Test
  description: "Testing b/bold for strong and i for italic shortcuts"
  content {
    h1:Shortcut Aliases

    p:this is b{very important} and also i{emphasized} text
    p:use bold{critical info} here and i{note this} too
    p:mixing strong{original} with b{shortcut} and bold{another}
    p:mixing italic{original} with i{shortcut} too

    p:this is b:bold to end of line
    p:this is bold:also bold to end of line
    p:this is i:italic to end of line

    ul {
      li:use b{quick bold} for speed
      li:use i{quick italic} for emphasis
      li:this has bold:everything bold here
      li:this has i:everything italic here
    }
  }
}
