skill {
  name: "Mixed Lists"
  description: "Testing ordered and unordered lists together"
  license: "MIT"
  version: "1.0"
  content {
    h1:Project Tasks
    h2:Priority Items
    ol {
      li:Fix the authentication bug
      li:Update the API documentation
      li:Deploy version 2.0
    }

    h2:Backlog
    ul {
      li:Refactor the logging module
      li:Add dark mode support
      li:Improve search performance
    }

    h2:Completed
    ol {
      li:Set up CI/CD pipeline
      li:Write unit tests for user service
    }

    h2:Notes
    ul {
      li:All tasks should have a corresponding ticket
      li:Use strong:labels to categorize issues
    }
  }
}
