skill {
  name: "Combined Elements Test"
  description: "Testing multiple element types together"
  license: "Apache-2.0"
  version: "2.0"
  content {
    h1:Getting Started {
      p:Welcome to the strong:project setup guide.
      blockquote:Make sure you have Node.js installed before proceeding.

      h2:Installation {
        ol {
          li:Clone the repository
          li:Run code:npm install
          li:Copy code:.env.example to code:.env
        }
      }

      h2:Configuration
      p:Edit the configuration file at code:config/default.json with your settings.
      hr
      h2:Running the App
      p:Use code:npm start to launch the application.
      p:Visit link:localhost:http://localhost:3000 in your browser.
    }
  }
}
