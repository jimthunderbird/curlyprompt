skill {
  name: "Mixed Image Syntax Test"
  description: "Testing both image syntax formats"
  version: "2.0"
  content {
    h1:Image Formats
    p:Old colon syntax:
    img:Classic Photo:images/classic.jpg
    p:New brace syntax:
    img{src:"https://cdn.example.com/hero.webp",alt:"Hero Banner"}
  }
}
