skill {
  name: "QRCode Vue Agent Guide"
  description: "Guidelines for AI agents working on the qrcode.vue repository"
  license: "MIT"
  version: "2.0"
  content {
    h1:Agent Guidelines for qrcode.vue
    p:This document provides guidelines for AI agents working on the qrcode.vue repository.

    h2:Build and Development Commands
    p:The project uses npm scripts defined in strong:package.json:
    ul {
      li:npm run dev to start development server with hot reload
      li:npm run build to build production bundles using Rollup
      li:npm test to run all tests using rstest
    }

    h2:Code Style Guidelines
    h3:Indentation and Formatting
    ul {
      li:strong:Indentation: 2 spaces, no tabs
      li:strong:Line endings: LF Unix
      li:strong:Trailing whitespace: Trimmed
      li:strong:Final newline: Yes
    }

    h3:TypeScript Conventions
    ul {
      li:Strict mode is always enabled
      li:Prefer explicit types for function parameters and return types
      li:Use type for simple aliases, interface for extensible object shapes
    }

    h2:Testing
    p:Tests written with strong{rstest} and strong{vue test utils}
    ul {
      li:Test files in test directory with .test.ts extension
      li:Use describe and it pattern
      li:Mount components with mount from vue test utils
    }
  }
}
