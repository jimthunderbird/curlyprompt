skill {
  name: "Git Workflow"
  description: "Git branching and workflow conventions"
  license: "MIT"
  version: "1.0"
  content {
    h1:Git Workflow
    p:This document describes our team's Git workflow.

    h2:Branch Naming
    ul {
      li:code:feature/description for new features
      li:code:bugfix/description for bug fixes
      li:code:hotfix/description for urgent production fixes
      li:code:release/version for release branches
    }

    h2:Commit Message Format
    p:Follow the strong:Conventional Commits specification:
    code: type(scope): description

    h2:Examples
    ul {
      li:code:feat(auth): add OAuth2 login
      li:code:fix(api): handle null response
      li:code:docs(readme): update installation steps
    }

    hr

    h2:Pull Request Process
    ol {
      li:Create a feature branch
      li:Make your changes and commit
      li:Push and open a pull request
      li:Request at least italic:two reviewers
      li:Address feedback and merge
    }

    blockquote:Squash commits before merging to main.
  }
}
