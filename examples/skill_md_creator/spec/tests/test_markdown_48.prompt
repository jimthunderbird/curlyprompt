skill {
  name: Image Brace Space Flexible
  description: Test img with flexible spacing before opening brace
  content {
    h1:Image Spacing Variants
    img{src:"http://www.dummyimage.com/no_space.jpg" alt:"no space"}
    img {src:"http://www.dummyimage.com/one_space.jpg" alt:"one space"}
    img   {src:"http://www.dummyimage.com/multi_space.jpg" alt:"multi space"}
    img  {  src:"http://www.dummyimage.com/mixed.jpg"   alt:"mixed spaces"}
  }
}
