skill {
  name: "Image Spacing Test"
  description: "Test flexible brace spacing for image tag"
  content {
    h1:Image Spacing
    img {src:"http://example.com/a.jpg" alt:"Spaced A"}
    img{src:"http://example.com/b.jpg" alt:"No Space B"}
    img   {src:"http://example.com/c.jpg" alt:"Multi Space C"}
  }
}
