skill {
  name: Table Header Tag Test
  description: "Testing th tag for table headers"
  content {
    h1:Product Catalog

    table {
      tr {
        th:Product
        th:Price
        th:Availability
      }
      tr {
        td:Laptop
        td:$999
        td:b{In Stock}
      }
      tr {
        td:Tablet
        td:$499
        td:i{Pre-order}
      }
    }

    table {
      tr {
        th: Name
        th: Role
      }
      tr {
        td: Alice
        td: Developer
      }
      tr {
        td: Bob
        td: Designer
      }
    }
  }
}
