skill {
  name: Shortcut In Headers and Blockquotes
  description: "Testing b/bold/i shortcuts in headers and blockquotes"
  content {
    h1:b{Bold Shortcut} in Header
    h2:i{Italic Shortcut} in Header
    h3:bold{Bold Keyword} in Header

    bq:remember to b{always} check i{twice} before deploying
    bq:this is bold:all bold from here

    p:a b{bold} word and a bold{also bold} word and an i{italic} word
  }
}
