skill {
  name: "Tag Open End Line Test"
  description: "Test tag open effect until end of line"
  content {
    h1:End of Line Effects
    p:This is strong:bold to the end of line
    p:This is italic:italic to the end of line
    p:This is code:code to the end of line
    p:This has strong{specific bold} and rest is normal.
    p:This has italic{specific italic} and rest is normal.
  }
}
