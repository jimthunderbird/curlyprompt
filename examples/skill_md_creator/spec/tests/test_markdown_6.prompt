skill {
  name: "Light Manager Air Integration"
  description: "Guidelines for the Home Assistant Light Manager Air integration"
  license: "MIT"
  version: "1.2.2"
  content {
    h1:Integration Guidelines
    p:This file provides coding and release guidelines for the Light Manager Air integration.

    h2:Commit Guidelines
    ul {
      li:Do NOT include generated with Claude Code in commit messages
      li:Commit messages should be clear, concise, and descriptive
      li:Use the strong:imperative mood in commit messages
      li:No need for co-author attribution to Claude
    }

    h2:Code Style Guidelines
    h3:General Principles
    ul {
      li:Maintain clean, readable, and consistent code
      li:Follow the Home Assistant code style guidelines
      li:Keep methods small and focused on a single task
      li:Use type hints where appropriate
      li:Write unit tests for new functionality
    }

    h3:Naming Conventions
    ul {
      li:Use descriptive names for classes, methods, and variables
      li:strong:snake_case for methods and variables
      li:strong:CamelCase for classes
      li:strong:UPPER_CASE for constants
    }

    h2:Release Process
    p:Tags should be created strong:without v prefix
    ul {
      li:The release title should simply be the version number
      li:Create tag with git tag command
      li:Push tag to origin
      li:Create release with gh release create
    }
  }
}
