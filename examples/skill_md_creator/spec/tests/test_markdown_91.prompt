skill {
  name: "Table Header TH Test"
  description: "Test th tag support for table headers"
  content {
    h1:Table with Headers
    table {
      tr {
        th:Header 1
        th:Header 2
        th:Header 3
      }
      tr {
        td:Row 1 Col 1
        td:Row 1 Col 2
        td:Row 1 Col 3
      }
      tr {
        td:Row 2 Col 1
        td:Row 2 Col 2
        td:Row 2 Col 3
      }
    }
  }
}
