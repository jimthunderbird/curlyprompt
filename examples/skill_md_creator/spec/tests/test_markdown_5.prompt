skill {
  name: Generalized KMeans Clustering Guide
  description: Repository guidelines for the generalized k-means clustering library
  license: Apache-2.0
  version: 1.0
  content {
    h1:Repository Guidelines
    p:Use this guide to make concise, high-signal contributions to the generalized k-means clustering library.

    h1:Project Structure
    ul {
      li:Scala sources live in src/main/scala
      li:Tests use ScalaTest under src/test/scala with Spark-local fixtures
      li:Python wrapper lives in python directory
      li:Documentation follows Diataxis structure in docs directory
    }

    h1:Build and Test Commands
    h2:strong:Scala Commands
    ul {
      li:sbt compile to compile against default Scala and Spark matrix
      li:sbt test for full JVM suite with ScalaTest
      li:sbt scalafmtAll then sbt scalastyle for required format and lint gates
      li:sbt coverage test coverageReport to generate coverage
    }

    h2:strong:Python Commands
    ul {
      li:cd python and pip install for setup
      li:pytest for running tests
    }

    h1:Coding Style
    ul {
      li:Scalafmt enforces 2-space indent and 100-col limit
      li:Prefer immutable vals and small helpers
      li:PascalCase for classes and objects
      li:camelCase for methods and vals
      li:Document public APIs with Scaladoc
    }

    h1:Commit Guidelines
    p:Use strong:conventional commits with format type scope subject
    ul {
      li:PRs should summarize behavior changes
      li:List executed commands
      li:Link issues with Closes number
    }
  }
}
