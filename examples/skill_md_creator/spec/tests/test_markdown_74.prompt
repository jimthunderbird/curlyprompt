skill {
  name: "Checklist Test"
  description: "Test checklist tag with item aliases"
  content {
    h1:Task Checklist
    checklist {
      item.checked:Complete setup
      itm.c:Write documentation
      item:Review code
      item.unchecked:Deploy to production
      itm.u:Run final tests
    }
    cl {
      item.checked:Alias checklist item
      item:Alias unchecked item
    }
  }
}
