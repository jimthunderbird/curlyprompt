skill {
  name: "Flexible Spacing Test"
  description: "Test flexible spacing between tag and brace"
  content {
    h1:Flexible Spacing
    p   {
      This paragraph has extra spaces before the brace.
    }
    ul    {
      li:Item with spaced ul brace
    }
    ol   {
      li:Ordered item with spaced ol brace
    }
  }
}
