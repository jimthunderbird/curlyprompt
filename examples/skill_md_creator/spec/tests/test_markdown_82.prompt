skill {
  name: "Image Oneliner Test"
  description: "Test image one-liner with flexible attributes"
  content {
    h1:Images
    img{src:"http://example.com/img1.jpg",alt:"Image One"}
    img{ src:"http://example.com/img2.jpg" , alt:"Image Two"}
    img{ src:"http://example.com/img3.jpg" alt:"Image Three"}
    img{  src:"http://example.com/img4.jpg"   alt:"Image Four"}
  }
}
