skill {
  name: "Shortcuts Test"
  description: "Test i for italic, b and bold for strong shortcuts"
  content {
    h1:Shortcut Formatting
    p:This is b{bold text} using b shortcut.
    p:This is bold{bold text} using bold shortcut.
    p:This is i{italic text} using i shortcut.
    p:Also b:everything bold to end
    p:Also i:everything italic to end
  }
}
