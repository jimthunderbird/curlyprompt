class App
{
  pi:Math.getPI()

  init() {
    - act as HTML/CSS/Javascript Expert
    - print this.view()    
  }

  getBookContent(book_url) {
    //apply defensive coding
    let book_content = get content from url {book_url}
    book_content = convert special characters in {book_content} to HTML entities 
    book_content = insert HTML line breaks before all newlines in {book_content}
    print {book_content}
    php exit
  }

  view() {
    this.getBookContent(request.post.book_url)

    html {
      h1 {
        text: {this.pi}
      }

      textbox.id:"book_url" {
        when enter key is pressed {
          let book_url = this.value
          div.id:"book_content".html = this.getBookContent(book_url) //bridge javascript and php with post request variable book_url, be defensive
        }
      }  

      div.id:"book_content" {
        html:""
        style {
          background:"wheat"
        }
      }
    }
  }
}
