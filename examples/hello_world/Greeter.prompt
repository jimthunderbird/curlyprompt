class Greeter
{
  greet() {
    let new_year_message = this.getNewYearMessage()
    let pi = Math.getPI()
    echo "this is the very simple hello message from greeter, also here is the {new_year_message}, pi day is around the corner, pi is {pi}\n"
  }

  getNewYearMessage() {
    return "happy new year 2016"
  }
}
